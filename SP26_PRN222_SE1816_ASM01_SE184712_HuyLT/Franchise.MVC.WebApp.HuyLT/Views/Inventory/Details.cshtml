@model Franchise.Entities.HuyLT.Models.Inventory
@{
    ViewData["Title"] = "Inventory Details";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Inventory</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Details</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 fw-bold">Inventory Record Details</h4>
                </div>
                <div class="card-body p-0">
                    <table class="table mb-0">
                        <tbody>
                            <tr>
                                <th class="ps-4 bg-light text-muted small text-uppercase" style="width: 30%">Ingredient</th>
                                <td class="ps-4 fw-bold text-primary">@(Model.Ingredient?.IngredientName ?? "N/A")</td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-muted small text-uppercase">Batch Number</th>
                                <td class="ps-4"><span class="badge bg-light text-dark border">@Model.BatchNumber</span></td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-muted small text-uppercase">Quantity</th>
                                <td class="ps-4">
                                    <span class="fw-bold fs-5">@Model.CurrentQuantity</span>
                                    <span class="text-muted fw-normal">@(Model.Ingredient?.UnitOfMeasure ?? "")</span>
                                </td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-muted small text-uppercase">Location</th>
                                <td class="ps-4">@Model.WarehouseLocation</td>
                            </tr>
                            <tr>
                                <th class="ps-4 bg-light text-muted small text-uppercase">Last Updated</th>
                                <td class="ps-4">@Model.LastUpdated?.ToString("F")</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
                <div class="card-footer bg-white py-3 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.InventoryId" class="btn btn-primary px-4 shadow-sm">Edit Entry</a>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Back to List</a>
                </div>
            </div>
        </div>
    </div>
</div>
