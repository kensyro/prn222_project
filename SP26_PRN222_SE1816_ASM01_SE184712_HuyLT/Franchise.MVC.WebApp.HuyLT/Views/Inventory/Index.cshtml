@model IEnumerable<Franchise.Entities.HuyLT.Models.Inventory>
@{
    var search = ViewData["Search"] as string;
    var ingredientId = ViewData["IngredientId"] as int?;
    var currentPage = ViewData["CurrentPage"] as int? ?? 1;
    var totalPages = ViewData["TotalPages"] as int? ?? 1;
    var ingredients = ViewData["Ingredients"] as IEnumerable<Franchise.Entities.HuyLT.Models.Ingredient>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Inventory Dashboard</h2>
            <p class="text-muted">Monitor and manage your store's stock levels</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            Add Stock Entry
        </a>
    </div>

    <!-- Filters and Search -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small text-uppercase text-muted fw-bold">Search</label>
                    <input type="text" name="search" value="@search" class="form-control" placeholder="Search batch number..." />
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-uppercase text-muted fw-bold">Filter by Ingredient</label>
                    <select name="ingredientId" class="form-select">
                        <option value="">All Ingredients</option>
                        @if (ingredients != null)
                        {
                            foreach (var ing in ingredients)
                            {
                                if (ing.IngredientId == ingredientId)
                                {
                                    <option value="@ing.IngredientId" selected>@ing.IngredientName</option>
                                }
                                else
                                {
                                    <option value="@ing.IngredientId">@ing.IngredientName</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">Filter</button>
                </div>
                <div class="col-md-1">
                    <a asp-action="Index" class="btn btn-link text-decoration-none">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary text-uppercase small">
                    <tr>
                        <th class="ps-4">Ingredient</th>
                        <th>Batch Number</th>
                        <th>Quantity</th>
                        <th>Location</th>
                        <th>Last Updated</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@(item.Ingredient?.IngredientName ?? "N/A")</div>
                                    <div class="small text-muted">ID: #@item.InventoryId</div>
                                </td>
                                <td><span class="badge bg-light text-dark border">@item.BatchNumber</span></td>
                                <td>
                                    <span class="fw-bold">@item.CurrentQuantity</span> 
                                    <small class="text-muted">@item.Ingredient?.UnitOfMeasure</small>
                                </td>
                                <td><i class="bi bi-geo-alt me-1"></i> @item.WarehouseLocation</td>
                                <td class="small">@item.LastUpdated?.ToString("g")</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.InventoryId" class="btn btn-sm btn-outline-primary shadow-sm" title="Edit">Edit</a>
                                        <a asp-action="Details" asp-route-id="@item.InventoryId" class="btn btn-sm btn-outline-info shadow-sm" title="Details">View</a>
                                        <a asp-action="Delete" asp-route-id="@item.InventoryId" class="btn btn-sm btn-outline-danger shadow-sm" title="Delete">Del</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="text-muted">No inventory records found.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link shadow-sm" asp-action="Index" asp-route-page="@i" asp-route-search="@search" asp-route-ingredientId="@ingredientId">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
