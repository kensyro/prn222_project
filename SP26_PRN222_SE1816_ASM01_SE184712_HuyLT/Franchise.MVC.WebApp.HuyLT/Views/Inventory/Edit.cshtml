@model Franchise.Entities.HuyLT.Models.Inventory
@{
    ViewData["Title"] = "Edit Inventory Entry";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-action="Index">Inventory</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit Entry</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-0 fw-bold">Edit Entry: @Model.BatchNumber</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="InventoryId" />
                        <input type="hidden" asp-for="StoreId" />

                        <div class="row g-3">
                            <div class="col-md-12">
                                <label asp-for="IngredientId" class="form-label fw-bold">Ingredient</label>
                                <select asp-for="IngredientId" class="form-select" asp-items="ViewBag.IngredientId">
                                    <option value="">-- Select Ingredient --</option>
                                </select>
                                <span asp-validation-for="IngredientId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="BatchNumber" class="form-label fw-bold">Batch Number</label>
                                <input asp-for="BatchNumber" class="form-control" />
                                <span asp-validation-for="BatchNumber" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CurrentQuantity" class="form-label fw-bold">Quantity</label>
                                <input asp-for="CurrentQuantity" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="CurrentQuantity" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="WarehouseLocation" class="form-label fw-bold">Warehouse Location</label>
                                <input asp-for="WarehouseLocation" class="form-control" />
                                <span asp-validation-for="WarehouseLocation" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="LastUpdated" class="form-label fw-bold">Updated Date</label>
                                <input asp-for="LastUpdated" class="form-control" type="datetime-local" value="@Model.LastUpdated?.ToString("yyyy-MM-ddTHH:mm")" />
                                <span asp-validation-for="LastUpdated" class="text-danger small"></span>
                            </div>

                            <div class="col-12 mt-4 d-flex gap-2">
                                <button type="submit" class="btn btn-primary px-4 shadow-sm">Save Changes</button>
                                <a asp-action="Index" class="btn btn-outline-secondary px-4">Return to List</a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
