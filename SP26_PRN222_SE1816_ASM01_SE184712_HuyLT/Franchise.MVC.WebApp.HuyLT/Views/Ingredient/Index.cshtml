@model IEnumerable<Franchise.Entities.HuyLT.Models.Ingredient>
@{
    var search = ViewData["Search"] as string;
    var currentPage = ViewData["CurrentPage"] as int? ?? 1;
    var totalPages = ViewData["TotalPages"] as int? ?? 1;
    ViewData["Title"] = "Ingredient Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">Ingredient Management</h2>
            <p class="text-muted">Manage your store ingredients and stock levels</p>
        </div>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            Create New Ingredient
        </a>
    </div>

    <!-- Filters and Search -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-6">
                    <div class="input-group">
                        <input type="text" name="search" value="@search" class="form-control" placeholder="Search by name or SKU..." />
                        <button type="submit" class="btn btn-secondary">Search</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-secondary text-uppercase small">
                    <tr>
                        <th class="ps-4">Ingredient</th>
                        <th>SKU</th>
                        <th>UoM</th>
                        <th>Price</th>
                        <th class="text-center">Min Stock</th>
                        <th>Status</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.IngredientName</div>
                                    <div class="small text-muted">ID: #@item.IngredientId</div>
                                </td>
                                <td><span class="badge bg-light text-dark border">@item.Sku</span></td>
                                <td>@item.UnitOfMeasure</td>
                                <td>@item.CurrentPrice?.ToString("N2")</td>
                                <td class="text-center">@item.MinimumStockLevel</td>
                                <td>
                                    @if (item.IsActive == true)
                                    {
                                        <span class="badge rounded-pill bg-success-subtle text-success border border-success-subtle">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger-subtle">Inactive</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.IngredientId" class="btn btn-sm btn-outline-primary" title="Edit">Edit</a>
                                        <a asp-action="Details" asp-route-id="@item.IngredientId" class="btn btn-sm btn-outline-info" title="Details">View</a>
                                        <a asp-action="Delete" asp-route-id="@item.IngredientId" class="btn btn-sm btn-outline-danger" title="Delete">Del</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center py-5">
                                <div class="text-muted">No ingredients found matching your criteria.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (totalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@search">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>
