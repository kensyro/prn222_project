@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<section class="py-5 text-center bg-light">
    <h1 class="display-4 mb-3">Welcome to Franchise Management</h1>
    <p class="lead mb-4">Easily manage your franchise stores, inventory, and ingredients in one place.</p>
    <div class="mt-3">
        <a class="btn btn-info m-2" href="/Ingredient/Index">Manage Ingredients</a>
        <a class="btn btn-success m-2" href="/Inventory/Index">Manage Inventory</a>
    </div>
</section>

<!-- Ingredient Section -->
<section class="container py-4">
    <h2 class="mb-3">Ingredient Overview</h2>
    <p>Manage ingredients, suppliers, and ensure quality for your franchise operations.</p>
    <a class="btn btn-outline-info" href="/Ingredient/Index">Go to Ingredient</a>
</section>

<!-- Inventory Section -->
<section class="container py-4">
    <h2 class="mb-3">Inventory Overview</h2>
    <p>View and manage your inventory, track quantities, batches, and warehouse locations.</p>
    <a class="btn btn-outline-success" href="/Inventory/Index">Go to Inventory</a>
</section>
