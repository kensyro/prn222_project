@*
    Franchise Store Info Page
*@
@model Franchise.Entities.HuyLT.Models.FranchiseStore
@{
    ViewData["Title"] = "Franchise Store Info";
}

<div class="container mt-5">
    <h2 class="mb-4">Franchise Store Information</h2>
    @if (Model != null)
    {
        <table class="table table-bordered table-striped">
            <tr><th>Store ID</th><td>@Model.StoreId</td></tr>
            <tr><th>Store Name</th><td>@Model.StoreName</td></tr>
            <tr><th>Owner Name</th><td>@Model.OwnerName</td></tr>
            <tr><th>Email</th><td>@Model.Email</td></tr>
            <tr><th>Phone</th><td>@Model.PhoneNumber</td></tr>
            <tr><th>Address</th><td>@Model.Address</td></tr>
        </table>
    }
    else
    {
        <div class="alert alert-warning">No store information found.</div>
    }
</div>
