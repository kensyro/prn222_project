@page
@model Franchise.Razor.WebApp.HuyLT.Pages.Ingredient.IndexModel

<h1>Ingredients — List</h1>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Sku</th>
            <th>Unit</th>
            <th>Price</th>
            <th>Active</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Items)
    {
        <tr>
            <td>@item.IngredientId</td>
            <td>@item.IngredientName</td>
            <td>@item.Sku</td>
            <td>@item.UnitOfMeasure</td>
            <td>@item.CurrentPrice</td>
            <td>@item.IsActive</td>
            <td>
                <a asp-page="./Details" asp-route-id="@item.IngredientId" class="btn btn-info btn-sm">Details</a>
                <a asp-page="./Edit" asp-route-id="@item.IngredientId" class="btn btn-warning btn-sm">Edit</a>
                <form method="post" asp-page-handler="Delete" class="d-inline">
                    <input type="hidden" name="id" value="@item.IngredientId" />
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this ingredient?');">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
<a asp-page="./Create" class="btn btn-primary">Create Ingredient</a>