@page "{id:int}"
@model Franchise.Razor.WebApp.HuyLT.Pages.Ingredient.DetailsModel

<h1>Ingredient — View</h1>

@if (Model.Item != null)
{
    <dl class="row">
        <dt class="col-sm-2">Id</dt><dd class="col-sm-10">@Model.Item.IngredientId</dd>
        <dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.Item.IngredientName</dd>
        <dt class="col-sm-2">Sku</dt><dd class="col-sm-10">@Model.Item.Sku</dd>
        <dt class="col-sm-2">Unit</dt><dd class="col-sm-10">@Model.Item.UnitOfMeasure</dd>
        <dt class="col-sm-2">Price</dt><dd class="col-sm-10">@Model.Item.CurrentPrice</dd>
        <dt class="col-sm-2">Active</dt><dd class="col-sm-10">@Model.Item.IsActive</dd>
    </dl>
    <a asp-page="./Index" class="btn btn-secondary">Back</a>
}
else
{
    <p>Ingredient not found.</p>
    <a asp-page="./Index">Back</a>
}