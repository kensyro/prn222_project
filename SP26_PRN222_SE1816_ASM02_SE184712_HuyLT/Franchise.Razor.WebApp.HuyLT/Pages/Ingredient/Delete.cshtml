@page "{id:int}"
@model Franchise.Razor.WebApp.HuyLT.Pages.Ingredient.DeleteModel

<h1>Delete Ingredient</h1>

@if (Model.Item != null)
{
    <form method="post">
        <input type="hidden" asp-for="Item.IngredientId" />
        <div class="alert alert-danger">
            Are you sure you want to delete <strong>@Model.Item.IngredientName</strong>?
        </div>
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="./Index" class="btn btn-secondary">Cancel</a>
    </form>
}
else
{
    <p>Ingredient not found.</p>
    <a asp-page="./Index">Back</a>
}