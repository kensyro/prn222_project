@page
@model Franchise.Razor.WebApp.HuyLT.Pages.FranchiseStore.CreateModel

<h1>Add Franchise Store</h1>

<form method="post" class="mb-3">
    <div asp-validation-summary="All" class="text-danger"></div>
    <div class="row">
        <div class="col-md-6 mb-2">
            <label asp-for="Input.StoreName" class="form-label"></label>
            <input asp-for="Input.StoreName" class="form-control" />
        </div>
        <div class="col-md-6 mb-2">
            <label asp-for="Input.Address" class="form-label"></label>
            <input asp-for="Input.Address" class="form-control" />
        </div>
        <div class="col-md-6 mb-2">
            <label asp-for="Input.OwnerName" class="form-label"></label>
            <input asp-for="Input.OwnerName" class="form-control" />
        </div>
        <div class="col-md-6 mb-2">
            <label asp-for="Input.PhoneNumber" class="form-label"></label>
            <input asp-for="Input.PhoneNumber" class="form-control" />
        </div>
        <div class="col-md-6 mb-2">
            <label asp-for="Input.Email" class="form-label"></label>
            <input asp-for="Input.Email" class="form-control" />
        </div>
        <div class="col-md-6 mb-2">
            <label asp-for="Input.OpeningDate" class="form-label"></label>
            <input asp-for="Input.OpeningDate" type="date" class="form-control" />
        </div>
        <div class="col-md-6 mb-2">
            <label asp-for="Input.ContractStatus" class="form-label"></label>
            <input asp-for="Input.ContractStatus" class="form-control" />
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-page="./Index" class="btn btn-secondary">Back</a>
</form>